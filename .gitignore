# Internal development/design artifacts — not part of the published product.
# Kept locally and in git history; excluded from the public repository.
docs/plans/
docs/specs/

# Root-level per-session working docs (PLAN/RESEARCH/PROGRESS scratch) — keep local, never
# publish. Root-anchored (leading /) so framework templates (templates/requirements.md) and
# test fixtures (tests/fixtures/plan-review/*.md) stay tracked.
/PLAN.md
/RESEARCH.md
/PROGRESS.md
/REQUIREMENTS.md
/PLAN-*.md
/RESEARCH-*.md
/PROGRESS-*.md

# Internal working/strategy drafts (licensing analysis, branding) — keep local.
docs/*-DRAFT.md

# Internal design specs (brainstorming output) — keep local, not published.
docs/superpowers/

# Subagent-driven-development process scratch (ledger + task reports) — local only.
.superpowers/

# macOS Finder metadata.
.DS_Store

# IDE / editor config — local only.
.idea/
*.iml

# Claude Code local settings (machine-specific paths, personal allowlist).
.claude/settings.local.json
